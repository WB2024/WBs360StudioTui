/* x360tm — Textual stylesheet */

Screen {
    background: #0d0d1a;
}

Header {
    background: #1a1a2e;
    color: #00d4ff;
}

Footer {
    background: #111111;
    color: #888888;
}

ConnectionBar {
    height: 1;
    background: #111111;
    color: #888888;
    padding: 0 1;
}

StatusBar {
    height: 1;
    background: #111111;
    color: #888888;
    padding: 0 1;
}

#main_menu {
    height: 1fr;
}

#main_menu_title {
    height: auto;
    padding: 1 2 0 2;
}

#main_title {
    text-style: bold;
    text-align: center;
    color: cyan;
    padding: 1 0;
}

#main_menu_center {
    height: 1fr;
    align: center middle;
}

#main_menu_buttons {
    width: auto;
    height: auto;
    border: round #00d4ff;
    padding: 1 2;
}

.menu_col {
    width: 28;
    height: auto;
    margin: 0 1;
}

.menu_button {
    width: 100%;
    margin-bottom: 1;
}

#browser_layout {
    layout: horizontal;
}

#browser_left {
    width: 60%;
    border-right: solid #1a1a2e;
}

#browser_right {
    width: 40%;
    padding: 1 2;
}

#filter_bar {
    height: auto;
    padding: 1;
    background: #111111;
}

#filter_bar Input {
    width: 1fr;
}

/* Library filter toggle button in browser filter bar */
.lib_filter_off {
    width: auto;
    min-width: 12;
    margin-left: 1;
    background: #1a1a2e;
    color: #888888;
    border: none;
}

.lib_filter_on {
    width: auto;
    min-width: 12;
    margin-left: 1;
    background: #004433;
    color: #00ff88;
    border: none;
}

/* Source filter button — cycles All / Online / Local */
.src_filter_all {
    width: auto;
    min-width: 14;
    margin-left: 1;
    background: #1a1a2e;
    color: #888888;
    border: none;
}

.src_filter_online {
    width: auto;
    min-width: 14;
    margin-left: 1;
    background: #001a44;
    color: #66aaff;
    border: none;
}

.src_filter_local {
    width: auto;
    min-width: 14;
    margin-left: 1;
    background: #1a3300;
    color: #88ff44;
    border: none;
}

/* Library screen layout */
#library_layout {
    layout: horizontal;
}

#library_left {
    width: 60%;
    border-right: solid #1a1a2e;
}

#library_right {
    width: 40%;
    padding: 1 2;
}

#library_toolbar {
    height: auto;
    padding: 1;
    background: #111111;
    align: left middle;
}

#library_toolbar Button {
    width: auto;
    margin-right: 1;
}

#game_list {
    height: 1fr;
}

#profiles_list {
    height: auto;
    max-height: 10;
}

/* Button rows inside VerticalScroll collapse to height 1 without an explicit height */
SettingsScreen Horizontal {
    height: 3;
}

#browse_buttons {
    margin-top: 1;
}

.browse_btn {
    width: 100%;
    margin-bottom: 1;
}

DataTable {
    height: 1fr;
}

#detail_pane {
    height: 1fr;
    overflow-y: auto;
}

.detail_label {
    color: #00d4ff;
    text-style: bold;
}

.error {
    color: #ff4444;
}

.success {
    color: #00ff88;
}

.muted {
    color: #888888;
}

/* X360Forge Tools screen layout helpers */
.xf_path_row {
    height: auto;
    margin-bottom: 1;
}

.xf_path_row Input {
    width: 1fr;
}

.xf_browse {
    width: auto;
    min-width: 10;
    margin-left: 1;
}

.xf_btn_row {
    height: auto;
    margin-bottom: 1;
}

.xf_btn_row Button {
    margin-right: 1;
}

#xforge_scroll {
    padding: 1 2;
}

#md_scroll {
    padding: 1 2;
}

#utils_menu {
    padding: 1 2;
}

#xforge_menu {
    padding: 1 2;
}

ProgressModal {
    align: center middle;
}

ProgressModal > Vertical {
    width: 80;
    height: auto;
    border: round #00d4ff;
    background: #1a1a2e;
    padding: 2 3;
}

#pm_log {
    height: 12;
    border: solid #333333;
    background: #0a0a14;
    margin: 1 0;
    padding: 0 1;
}

ConnectionScreen {
    align: center middle;
}

ConnectionScreen > Vertical {
    width: 60;
    height: auto;
    border: round #00d4ff;
    background: #1a1a2e;
    padding: 2 3;
}

InstallChoiceModal {
    align: center middle;
}

InstallChoiceModal > Vertical {
    width: 50;
    height: auto;
    border: round #00d4ff;
    background: #1a1a2e;
    padding: 2 3;
}

UsbChoiceModal {
    align: center middle;
}

UsbChoiceModal > Vertical {
    width: 70;
    height: auto;
    border: round #00d4ff;
    background: #1a1a2e;
    padding: 2 3;
}

SplashScreen {
    align: center middle;
}

SplashScreen > Vertical {
    width: auto;
    height: auto;
    align: center middle;
}

#splash_log {
    color: #888888;
    margin-top: 1;
}

/* File Manager — dual-pane layout */

#fm_panels {
    height: 1fr;
}

#fm_local_panel,
#fm_remote_panel {
    width: 1fr;
    height: 1fr;
    border: solid #333333;
    padding: 0;
}

#fm_local_panel.panel-active {
    border: solid #00d4ff;
}

#fm_remote_panel.panel-active {
    border: solid #ffd700;
}

.panel-path-bar {
    height: 1;
    background: #0d1a2e;
    color: #aaaaaa;
    padding: 0 1;
}

#fm_local_panel.panel-active .panel-path-bar {
    color: #00d4ff;
    background: #0a1520;
}

#fm_remote_panel.panel-active .panel-path-bar {
    color: #ffd700;
    background: #1a1200;
}

#fm_local_table,
#fm_remote_table {
    height: 1fr;
}

#fm_toolbar {
    height: auto;
    padding: 0 1;
    background: #111111;
}

#fm_toolbar Button {
    width: auto;
    margin-right: 1;
}

ConfirmDeleteModal {
    align: center middle;
}

#confirm_box {
    width: 60;
    height: auto;
    border: round #ff4444;
    background: #1a1a2e;
    padding: 2 3;
}

#confirm_title {
    margin-bottom: 1;
}

#confirm_name {
    color: #ffffff;
    margin-bottom: 1;
}

#confirm_warn {
    margin-bottom: 1;
}

#confirm_msg {
    color: #888888;
    margin-bottom: 2;
}

#confirm_btns {
    height: 3;
}

#confirm_btns Button {
    margin-right: 1;
}

RenameModal {
    align: center middle;
}

#rename_box {
    width: 60;
    height: auto;
    border: round #00d4ff;
    background: #1a1a2e;
    padding: 2 3;
}

#rename_title {
    margin-bottom: 1;
}

#rename_input {
    margin-bottom: 2;
}

#rename_btns {
    height: 3;
}

#rename_btns Button {
    margin-right: 1;
}

/* Torrent selector screen */

ConfirmDownloadModal {
    align: center middle;
}

ConfirmTidyModal {
    align: center middle;
}

#tsel_log {
    height: auto;
    min-height: 3;
    max-height: 10;
    padding: 1 2;
    background: #0d1a2e;
    border: solid #1a3a5a;
    margin: 0 0 1 0;
}

#tsel_summary_row {
    height: auto;
    padding: 0 1;
}

#tsel_actions {
    height: auto;
    padding: 0 1;
}

#tsel_actions Button {
    margin-right: 1;
}

#tsel_search {
    margin: 0 1;
}

/* New Game Processing pipeline screen */

#pip_stage_bar {
    height: 3;
    padding: 0 1;
}

.pip_stage {
    width: 1fr;
    text-align: center;
    background: $surface;
    border: solid $panel;
    padding: 0 1;
    color: $text-muted;
}

.pip_stage_active {
    background: $primary;
    color: $text;
    border: solid $primary-lighten-2;
}

.pip_stage_done {
    background: $success-darken-3;
    color: $success;
    border: solid $success-darken-1;
}

#pip_info {
    height: auto;
    padding: 0 1;
    color: $text-muted;
}

#pip_actions {
    height: auto;
    padding: 0 1;
}

#pip_actions Button {
    margin-right: 1;
}

#pip_table {
    height: 1fr;
}

#pip_log {
    height: auto;
    min-height: 2;
    max-height: 6;
    padding: 0 2;
    background: #0d1a2e;
    border: solid #1a3a5a;
    margin: 0 0 1 0;
}

/* XboxUnity Title Update search screen */

#xu_search_stage,
#xu_tu_stage {
    layout: horizontal;
    height: 1fr;
}

#xu_search_left,
#xu_tu_left {
    width: 45%;
    border-right: solid #1a1a2e;
}

#xu_search_right,
#xu_tu_right {
    width: 55%;
    padding: 1 2;
}

#xu_search_bar {
    height: auto;
    padding: 1;
    background: #111111;
}

#xu_search_bar Input {
    width: 1fr;
}

#xu_search_bar Button {
    width: auto;
    margin-left: 1;
}

#xu_lib_label {
    height: auto;
    padding: 0 1;
    color: #888888;
}

#xu_library_list {
    height: 1fr;
}

#xu_tu_toolbar {
    height: auto;
    padding: 1;
    background: #111111;
}

#xu_tu_toolbar Button {
    width: auto;
    margin-right: 1;
}

#xu_game_title {
    height: auto;
    padding: 0 1 1 1;
}

#xu_search_hint {
    height: auto;
    padding: 0 0 1 0;
    color: #888888;
}

#xu_tu_detail {
    height: 1fr;
    overflow-y: auto;
}

